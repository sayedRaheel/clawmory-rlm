#!/usr/bin/env bash

set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$DIR"

if [ -f "$DIR/.venv/bin/python" ]; then
    PYTHON_BIN="$DIR/.venv/bin/python"
else
    PYTHON_BIN="${PYTHON_BIN:-python3}"
fi

export PYTHONPATH="$DIR${PYTHONPATH:+:$PYTHONPATH}"

exec "$PYTHON_BIN" -m clawmory_rlm.cli "$@"
